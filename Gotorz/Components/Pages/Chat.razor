@page "/chat"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Web   @* for KeyboardEventArgs *@
@using Gotorz.Models
@inject NavigationManager NavigationManager

<h3>Live Chat</h3>

@if (!IsConnected)
{
    <p><em>Connecting…</em></p>
}
else
{
    <div class="chat-window" style="border:1px solid #ccc; padding:1rem; height:300px; overflow-y:auto;">
        @foreach (var msg in messages)
        {
            <div class="mb-2">
                <strong>@msg.SenderName</strong>
                <span class="text-muted" style="font-size:0.8em;">
                    [@msg.SentAt.ToLocalTime():HH:mm:ss]
                </span>
                <div>@msg.Text</div>
            </div>
        }
    </div>

    <div class="input-group mt-2">
        <input class="form-control"
               @bind="currentMessage"
               placeholder="Type a message…"
               @onkeydown="HandleKey" />
        <button class="btn btn-primary" @onclick="Send">Send</button>
    </div>
}

@code {
    private HubConnection hubConnection;
    private List<ChatMessage> messages = new();
    private string currentMessage;

    // Temporary; swap out for actual user identity later
    private string UserName { get; } = $"User{new Random().Next(1000, 9999)}";

    private bool IsConnected =>
        hubConnection is not null &&
        hubConnection.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        // 1) Build the connection to the exact same path you mapped in Program.cs:
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        // 2) Register a handler for messages the server broadcasts:
        hubConnection.On<ChatMessage>("ReceiveMessage", (message) =>
        {
            messages.Add(message);
            // Tell Blazor to re-render
            InvokeAsync(StateHasChanged);
        });

        // 3) Actually start the connection:
        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"SignalR connection failed: {ex}");
        }
    }

    private async Task Send()
    {
        if (!string.IsNullOrWhiteSpace(currentMessage))
        {
            await hubConnection.SendAsync("SendMessage", UserName, currentMessage);
            currentMessage = "";
        }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Send();
        }
    }
}